<%
  const sectionMeta = {
    dashboard: {
      kicker: 'Controle central',
      title: 'Dashboard administrativo',
      copy: 'Visibilidade de operacao, seguranca, rastreabilidade e processamento em um unico painel.',
    },
    users: {
      kicker: 'Seguranca e pessoas',
      title: 'Usuarios, perfis e credenciais',
      copy: 'Gerencie acessos por CPF, politicas de senha, recuperacao e trilha administrativa.',
    },
    accessLogs: {
      kicker: 'Rastreabilidade',
      title: 'Acessos de usuarios',
      copy: 'Acompanhe logins, navegacao, rotas acessadas, metodos, IPs e eventos operacionais.',
    },
    searchHistory: {
      kicker: 'Rastreabilidade',
      title: 'Historico de pesquisas',
      copy: 'Consulte termos pesquisados, filtros usados, volume de resultados e comportamento de consulta.',
    },
    settings: {
      kicker: 'Preferencias',
      title: 'Parametros operacionais do sistema',
      copy: 'Centralize configuracoes de execucao, seguranca e comportamento do ambiente.',
    },
    indexingRun: {
      kicker: 'Indexador',
      title: 'Operacao do indexador',
      copy: 'Acompanhe fila, progresso, documentos em processamento e lotes recentes do motor de indexacao.',
    },
    indexingSettings: {
      kicker: 'Indexador',
      title: 'Configuracao do indexador',
      copy: 'Defina lote, modo de extracao e politicas de reprocesso antes de iniciar a fila.',
    },
    downloadsRun: {
      kicker: 'Downloads',
      title: 'Operacao de downloads',
      copy: 'Monitore o fluxo de arquivos, progresso total, falhas e pendencias da coleta.',
    },
    downloadsSettings: {
      kicker: 'Downloads',
      title: 'Configuracao de downloads',
      copy: 'Ajuste concorrencia, timeout, tentativas e politica de sobrescrita da fila.',
    },
    logs: {
      kicker: 'Suporte tecnico',
      title: 'Logs tecnicos e falhas operacionais',
      copy: 'Consolide diagnosticos, eventos recentes, erros de lote e sinais do motor interno.',
    },
    maintenanceRun: {
      kicker: 'Tratamento',
      title: 'Operacao de tratamento',
      copy: 'Revise candidatos, gere previews e execute reprocessos imediatos sobre o acervo.',
    },
    maintenanceSettings: {
      kicker: 'Tratamento',
      title: 'Configuracao de tratamento',
      copy: 'Defina estrategias, limites e padroes de limpeza para o fluxo de recuperacao do acervo.',
    },
    enrichmentRun: {
      kicker: 'IA e midia',
      title: 'Operacao de enriquecimento',
      copy: 'Controle a execucao da fila de resumos e miniaturas e acompanhe o que esta sendo processado.',
    },
    enrichmentSettings: {
      kicker: 'IA e midia',
      title: 'Configuracao de enriquecimento',
      copy: 'Defina provider, modelo, batch e politicas de resumo e imagens para o processo de IA.',
    },
    localLibraryRun: {
      kicker: 'Acervo local',
      title: 'Operacao da biblioteca local',
      copy: 'Monitore arquivos detectados, estado da pasta local e resultados da sincronizacao.',
    },
    localLibrarySettings: {
      kicker: 'Acervo local',
      title: 'Configuracao da biblioteca local',
      copy: 'Defina o comportamento da ingestao local e como a sincronizacao automatica deve agir no servidor.',
    },
  };
  const currentSection = sectionMeta[activeSection] || sectionMeta.dashboard;
%>
<%- include('partials/head', { pageTitle, bodyPage: `config-${activeSection}` }) %>
<div class="shell">
  <main class="config-shell config-page">
    <header class="admin-topbar">
      <div class="admin-topbar-start">
        <button class="admin-menu-button" type="button" aria-label="Abrir menu" title="Menu em evolucao">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <a class="admin-brand" href="/">
          <span class="admin-brand-wordmark" aria-hidden="true">
            <span class="brand-blue">A</span><span class="brand-red">c</span><span class="brand-yellow">e</span><span class="brand-blue">r</span><span class="brand-green">v</span><span class="brand-red">o</span>
          </span>
        </a>
      </div>

      <div class="admin-topbar-end">
        <button class="admin-notification-button" type="button" aria-label="Notificacoes">
          <img src="/bell-solid-108.png" alt="" />
        </button>

        <% if (currentUser) { %>
          <div class="admin-user-badge">
            <div class="admin-user-copy">
              <strong><%= currentUser.full_name %></strong>
              <span>Cidade</span>
            </div>
            <span class="admin-user-avatar"><%= String(currentUser.full_name || 'A').trim().charAt(0).toUpperCase() || 'A' %></span>
          </div>
        <% } %>

        <button id="logoutButton" class="ghost-button admin-logout-button" type="button">Sair</button>
      </div>
    </header>

    <section class="config-admin-layout hidden" id="configPanel">
      <%- include('partials/config-sidebar', { activeSection, currentUser }) %>

      <section class="config-workspace">
        <section class="config-content">
          <header class="config-page-head">
            <div>
              <p class="panel-kicker"><%= currentSection.kicker %></p>
              <h1 id="configTitle"><%= currentSection.title %></h1>
              <p class="config-workspace-copy" id="configLead"><%= currentSection.copy %></p>
            </div>
          </header>

          <% if (activeSection === 'dashboard') { %>
            <%- include('partials/config-dashboard') %>
          <% } %>

          <% if (activeSection === 'settings') { %>
            <%- include('partials/config-settings') %>
          <% } %>

          <% if (activeSection === 'indexingRun') { %>
            <%- include('partials/config-indexing-run') %>
          <% } %>

          <% if (activeSection === 'indexingSettings') { %>
            <%- include('partials/config-indexing-settings') %>
          <% } %>

          <% if (activeSection === 'downloadsRun') { %>
            <%- include('partials/config-downloads-run') %>
          <% } %>

          <% if (activeSection === 'downloadsSettings') { %>
            <%- include('partials/config-downloads-settings') %>
          <% } %>

          <% if (activeSection === 'logs') { %>
            <%- include('partials/config-logs') %>
          <% } %>

          <% if (activeSection === 'accessLogs') { %>
            <%- include('partials/config-access-logs') %>
          <% } %>

          <% if (activeSection === 'searchHistory') { %>
            <%- include('partials/config-search-history') %>
          <% } %>

          <% if (activeSection === 'maintenanceRun') { %>
            <%- include('partials/config-maintenance-run') %>
          <% } %>

          <% if (activeSection === 'maintenanceSettings') { %>
            <%- include('partials/config-maintenance-settings') %>
          <% } %>

          <% if (activeSection === 'enrichmentRun') { %>
            <%- include('partials/config-enrichment-run') %>
          <% } %>

          <% if (activeSection === 'enrichmentSettings') { %>
            <%- include('partials/config-enrichment-settings') %>
          <% } %>

          <% if (activeSection === 'localLibraryRun') { %>
            <%- include('partials/config-local-library-run') %>
          <% } %>

          <% if (activeSection === 'localLibrarySettings') { %>
            <%- include('partials/config-local-library-settings') %>
          <% } %>

          <% if (activeSection === 'users') { %>
            <%- include('partials/config-users') %>
          <% } %>
        </section>
      </section>
    </section>
  </main>
</div>

<%- include('partials/terms-modal', { currentUser }) %>

<script src="/js/config-page.js"></script>
<%- include('partials/footer-scripts') %>
