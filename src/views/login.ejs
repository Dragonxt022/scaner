<%- include('partials/head', { pageTitle, bodyClass: 'login-page' }) %>
<div class="shell login-shell">
  <main class="login-layout login-layout-auth">
    <section class="login-card auth-stage-card">
      <div class="auth-brand-lockup" aria-label="Acervo Publico">
        <p class="auth-brand-kicker">Pesquisa documental</p>
        <div class="auth-brand-wordmark" aria-hidden="true">
          <span class="brand-blue">A</span><span class="brand-red">c</span><span class="brand-yellow">e</span><span class="brand-blue">r</span><span class="brand-green">v</span><span class="brand-red">o</span>
        </div>
        <p class="auth-brand-subtitle">Publico</p>
      </div>

      <section class="auth-screen active" data-auth-screen="login">
        <div class="auth-screen-head">
          <h3>ENTRAR</h3>
          <p class="detail-hero-copy">Digite suas credenciais para te acesso ao sistema</p>
        </div>

        <form id="loginForm" class="login-form">
          <input id="loginCpf" class="auth-input" type="text" inputmode="numeric" maxlength="14" placeholder="Seu C.P.F" autocomplete="username" />
          <input id="loginPassword" class="auth-input" type="password" placeholder="Senha" autocomplete="current-password" />
          <button class="primary-button login-submit auth-submit" type="submit">ACESSAR</button>
          <label class="auth-remember-line">
            <input type="checkbox" id="rememberLogin" />
            <span>Permanecer conectado</span>
          </label>
        </form>

        <div class="auth-inline-links">
          <button type="button" class="auth-link-button" data-auth-target="request">Solicitar acesso?</button>
        </div>

        <p id="loginFeedback" class="detail-inline-feedback auth-feedback"></p>
        <p class="auth-version">Versao 1.0 - beta</p>
      </section>

      <section class="auth-screen" data-auth-screen="request" hidden>
        <div class="auth-screen-head">
          <h3>Solicitacao de acesso</h3>
          <p class="detail-hero-copy">Informe CPF, nome completo e senha desejada para criar seu acesso.</p>
        </div>

        <form id="passwordResetRequestForm" class="login-form">
          <input id="requestFullName" class="auth-input" type="text" placeholder="Nome completo" autocomplete="name" />
          <input id="requestPassword" class="auth-input" type="password" placeholder="Senha desejada" autocomplete="new-password" />
          <input id="resetRequestCpf" class="auth-input" type="text" inputmode="numeric" maxlength="14" placeholder="Seu C.P.F" />
          <button class="ghost-button login-submit secondary-submit auth-submit" type="submit">ENVIAR SOLICITACAO</button>
        </form>

        <div class="auth-inline-links">
          <button type="button" class="auth-link-button" data-auth-target="login">Voltar a pagina de login</button>
        </div>

        <p id="requestFeedback" class="detail-inline-feedback auth-feedback"></p>
        <p class="auth-version">Versao 1.0 - beta</p>
      </section>

      <section class="auth-screen auth-screen-sent" data-auth-screen="sent" hidden>
        <div class="auth-screen-head auth-screen-head-sent">
          <img class="auth-sent-illustration" src="/carta.png" alt="Carta enviada" />
          <h3 class="auth-sent-title">Enviado!</h3>
          <p class="detail-hero-copy auth-sent-copy">Sua solicitacao foi enviada, aguarde um administrador realizar aprovacao!</p>
        </div>

        <div class="auth-inline-links">
          <button type="button" class="auth-link-button" data-auth-target="login">Voltar a pagina de login</button>
        </div>

        <p class="auth-version">Versao 1.0 - beta</p>
      </section>
    </section>
  </main>
</div>
<script>
  window.__LOGIN_CONTEXT__ = {
    next: <%- JSON.stringify(typeof next !== 'undefined' ? next : '') %>
  };
</script>
<script src="/js/login-page.js"></script>
<%- include('partials/footer-scripts') %>
