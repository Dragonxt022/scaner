<article class="config-card">
  <div class="section-head">
    <div>
      <p class="panel-kicker">Indexacao</p>
      <h3>Fila de texto</h3>
    </div>
  </div>

  <div class="form-grid">
    <label>
      <span>Lote</span>
      <select id="batchLimit">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="25">25</option>
        <option value="50">50</option>
      </select>
    </label>
    <label>
      <span>Modo</span>
      <select id="indexMode">
        <option value="hybrid" selected>Hibrido</option>
        <option value="native">Texto nativo</option>
        <option value="ocr">OCR forcado</option>
      </select>
    </label>
  </div>

  <label class="toggle-line strong-line">
    <input id="retryFailuresToggle" type="checkbox" />
    <span>Tentar novamente falhas</span>
  </label>
  <label class="toggle-line strong-line">
    <input id="fullProcessToggle" type="checkbox" checked />
    <span>Realizar todo o processo se necessario (resumo e imagens)</span>
  </label>

  <div class="button-row">
    <button id="reindexStart" class="primary-button" type="button">Iniciar</button>
    <button id="reindexStop" class="ghost-button danger-button" type="button">Parar</button>
  </div>

  <div class="progress-block">
    <div class="progress-track">
      <div id="indexerProgressBar" class="progress-fill" style="width: 0%"></div>
    </div>
    <div class="progress-copy">
      <span id="indexerProgressLabel">0%</span>
      <span id="indexerCounts">0 processados</span>
    </div>
  </div>

  <div class="table-shell">
    <table class="data-table data-table-compact">
      <thead>
        <tr>
          <th>Status</th>
          <th>Lote atual</th>
          <th>Indexados</th>
          <th>Erros</th>
          <th>Pendentes</th>
          <th>Media</th>
          <th>Gargalo</th>
          <th>Ultimo item</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td id="indexerStatusMode">Parado</td>
          <td id="indexerCurrentBatch">0</td>
          <td id="indexerIndexedTotal">0</td>
          <td id="indexerErrorTotal">0</td>
          <td id="indexerPendingGroups">0</td>
          <td id="indexerAvgRate">--</td>
          <td id="indexerBottleneckStage">--</td>
          <td id="indexerLastItemTime">--</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="table-shell">
    <table class="data-table data-table-compact">
      <thead>
        <tr>
          <th>Docs pendentes</th>
          <th>Docs processando</th>
          <th>Grupos com falha</th>
          <th>Grupos pausados</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td id="indexerPendingDocuments">0</td>
          <td id="indexerProcessingDocuments">0</td>
          <td id="indexerFailedGroups">0</td>
          <td id="indexerPausedGroups">0</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="config-section-grid compact-grid">
    <div>
      <h4 class="config-subtitle">Documento em processamento</h4>
      <div id="indexerActiveItems" class="table-shell"></div>
    </div>
    <div>
      <h4 class="config-subtitle">Ultimo documento concluido</h4>
      <div id="indexerLastItemCard" class="table-shell"></div>
    </div>
  </div>

  <section class="queue-panel">
    <div class="section-head">
      <div>
        <p class="panel-kicker">Fila</p>
        <h3>Detalhes e acoes</h3>
      </div>
    </div>

    <div class="form-grid queue-toolbar">
      <label>
        <span>Filtro</span>
        <select id="indexerQueueFilter">
          <option value="all" selected>Todas</option>
          <option value="processing">Processando</option>
          <option value="pending">Pendentes</option>
          <option value="error">Com falha</option>
          <option value="paused">Pausadas</option>
        </select>
      </label>
      <label>
        <span>Buscar</span>
        <input id="indexerQueueSearch" type="text" placeholder="ID, descricao, caixa, classificacao" />
      </label>
    </div>

    <div class="button-row">
      <button id="indexerQueueRefresh" class="ghost-button" type="button">Atualizar fila</button>
    </div>

    <label class="queue-inline-form">
      <span>Adicionar por ID</span>
      <div class="queue-inline-action">
        <input id="indexerQueueManualId" type="text" inputmode="numeric" placeholder="Ex.: 12345" />
        <button id="indexerQueueAddButton" class="primary-button" type="button">Adicionar</button>
      </div>
    </label>

    <p id="indexerQueueFeedback" class="config-note">Use a fila para acompanhar, pausar e reenfileirar grupos.</p>
    <div id="indexerQueueList" class="table-shell"></div>
  </section>

  <div class="config-section-grid compact-grid">
    <div>
      <h4 class="config-subtitle">Lotes recentes</h4>
      <div class="table-toolbar">
        <label>
          <span>Filtrar lotes</span>
          <input id="indexerBatchSearch" type="text" placeholder="Lote, modo ou data" />
        </label>
      </div>
      <div id="indexerBatchHistory" class="table-shell"></div>
    </div>
    <div>
      <h4 class="config-subtitle">Log operacional</h4>
      <div class="table-toolbar">
        <label>
          <span>Filtrar log</span>
          <input id="indexerOperationSearch" type="text" placeholder="Nivel, mensagem, lote, documento" />
        </label>
      </div>
      <div id="indexerOperationLogs" class="table-shell"></div>
    </div>
  </div>

  <p id="indexerStatusText" class="config-note">Aguardando inicio.</p>
  <p id="indexerUpdatedAt" class="config-note">--</p>
  <p id="indexerLastError" class="error-copy"></p>
</article>
