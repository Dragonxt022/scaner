<article class="config-card">
  <div class="config-dashboard-head">
    <div>
      <p class="panel-kicker">Dashboard</p>
      <h3>Ola seja bem vindo <%= (typeof currentUser !== 'undefined' && currentUser && currentUser.full_name) ? currentUser.full_name.toUpperCase() : 'USUARIO' %></h3>
    </div>
    <div class="config-actions">
      <button id="refreshStats" type="button">Atualizar</button>
      <button id="syncCatalog" type="button">Sincronizar</button>
    </div>
  </div>
  <div id="configStats" class="stats-grid stats-grid-hero"></div>
  <p class="config-note" id="configFeedback">Aguardando acao.</p>
  <p class="config-note" id="databaseStrategy">Carregando estrategia de banco.</p>
</article>

<article class="config-card config-card-soft">
  <div class="section-head config-shortcuts-head">
    <div>
      <p class="panel-kicker">Atalhos rapidos</p>
      <h3>Ferramentas mais usadas</h3>
    </div>
  </div>

  <div class="config-shortcuts-grid">
    <a class="config-shortcut-pill" href="/config/users">ICON | Solicitacoes</a>
    <a class="config-shortcut-pill alt" href="/config/indexing/run">ICON | Indexador</a>
    <a class="config-shortcut-pill alt-2" href="/config/access-logs">ICON | Auditoria</a>
    <a class="config-shortcut-pill alt-3" href="/config/logs">ICON | Logs</a>
  </div>
</article>
