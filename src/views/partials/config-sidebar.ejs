<%
  const isUsersOpen = ['users', 'accessLogs', 'searchHistory'].includes(activeSection);
  const isGestaoOpen = isUsersOpen;
  const isIndexingOpen = ['indexingRun', 'indexingSettings'].includes(activeSection);
  const isDownloadsOpen = ['downloadsRun', 'downloadsSettings'].includes(activeSection);
  const isMaintenanceOpen = ['maintenanceRun', 'maintenanceSettings'].includes(activeSection);
  const isEnrichmentOpen = ['enrichmentRun', 'enrichmentSettings'].includes(activeSection);
  const isLocalLibraryOpen = ['localLibraryRun', 'localLibrarySettings'].includes(activeSection);
%>

<aside class="config-sidebar">
  <div class="config-sidebar-card">
    <div class="config-sidebar-profile">
      <p class="config-nav-title">Início</p>
      <nav class="config-nav">
        <a class="config-nav-button <%= activeSection === 'dashboard' ? 'active' : '' %>" href="/config">
          <span class="config-nav-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M4 5h7v6H4zM13 5h7v10h-7zM4 13h7v6H4zM13 17h7v2h-7z"></path>
            </svg>
          </span>
          <span class="config-nav-copy">
            <strong>Dashboard</strong>
          </span>
        </a>
      </nav>
    </div>

    <div class="config-nav-group config-nav-collapsible" data-accordion-scope="root" data-collapsed="<%= isGestaoOpen ? 'false' : 'true' %>">
      <div class="config-nav-group-head">
        <p class="config-nav-title">Gestão</p>
      </div>

      <button class="config-nav-toggle" type="button" aria-expanded="<%= isGestaoOpen ? 'true' : 'false' %>">
        <span class="config-nav-toggle-main">
          <span class="config-nav-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M16 19a4 4 0 0 0-8 0"></path>
              <circle cx="12" cy="11" r="3"></circle>
              <path d="M5 19a7 7 0 0 1 14 0"></path>
            </svg>
          </span>
          <span class="config-nav-copy">
            <strong>Usuários</strong>
          </span>
        </span>
        <span class="config-nav-toggle-caret" aria-hidden="true">v</span>
      </button>

      <nav class="config-nav-panel">
        <a class="config-nav-link-row <%= activeSection === 'users' ? 'active' : '' %>" href="/config/users">Todos</a>
        <a class="config-nav-link-row <%= activeSection === 'users' ? 'active' : '' %>" href="/config/users#requests">Solicitações</a>
        <a class="config-nav-link-row <%= activeSection === 'users' ? 'active' : '' %>" href="/config/users#userFullName">Cadastrar</a>
        <a class="config-nav-link-row <%= activeSection === 'accessLogs' ? 'active' : '' %>" href="/config/access-logs">Acessos</a>
        <a class="config-nav-link-row <%= activeSection === 'searchHistory' ? 'active' : '' %>" href="/config/search-history">Pesquisas</a>
      </nav>
    </div>

    <nav class="config-nav">

      <div class="config-nav-tool config-nav-collapsible" data-accordion-scope="root" data-collapsed="<%= isIndexingOpen ? 'false' : 'true' %>">
        <button class="config-nav-toggle" type="button" aria-expanded="<%= isIndexingOpen ? 'true' : 'false' %>">
          <span class="config-nav-toggle-main">
            <span class="config-nav-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M4 7h16"></path>
                <path d="M4 12h10"></path>
                <path d="M4 17h7"></path>
                <path d="M17 10l3 2-3 2"></path>
              </svg>
            </span>
            <span class="config-nav-copy">
              <strong>Indexador</strong>
            </span>
          </span>
          <span class="config-nav-toggle-caret" aria-hidden="true">v</span>
        </button>
        <nav class="config-nav-panel config-nav-subpanel">
          <a class="config-nav-link-row <%= activeSection === 'indexingRun' ? 'active' : '' %>" href="/config/indexing/run">Uso</a>
          <a class="config-nav-link-row <%= activeSection === 'indexingSettings' ? 'active' : '' %>" href="/config/indexing/settings">Configuração</a>
        </nav>
      </div>

      <div class="config-nav-tool config-nav-collapsible" data-accordion-scope="root" data-collapsed="<%= isDownloadsOpen ? 'false' : 'true' %>">
        <button class="config-nav-toggle" type="button" aria-expanded="<%= isDownloadsOpen ? 'true' : 'false' %>">
          <span class="config-nav-toggle-main">
            <span class="config-nav-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M12 4v10"></path>
                <path d="M8 10l4 4 4-4"></path>
                <path d="M5 19h14"></path>
              </svg>
            </span>
            <span class="config-nav-copy">
              <strong>Downloads</strong>
            </span>
          </span>
          <span class="config-nav-toggle-caret" aria-hidden="true">v</span>
        </button>
        <nav class="config-nav-panel config-nav-subpanel">
          <a class="config-nav-link-row <%= activeSection === 'downloadsRun' ? 'active' : '' %>" href="/config/downloads/run">Uso</a>
          <a class="config-nav-link-row <%= activeSection === 'downloadsSettings' ? 'active' : '' %>" href="/config/downloads/settings">Configuração</a>
        </nav>
      </div>

      <a class="config-nav-link-row <%= activeSection === 'logs' ? 'active' : '' %>" href="/config/logs">Logs</a>

      <div class="config-nav-tool config-nav-collapsible" data-accordion-scope="root" data-collapsed="<%= isMaintenanceOpen ? 'false' : 'true' %>">
        <button class="config-nav-toggle" type="button" aria-expanded="<%= isMaintenanceOpen ? 'true' : 'false' %>">
          <span class="config-nav-toggle-main">
            <span class="config-nav-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M14 7l3-3 3 3-3 3"></path>
                <path d="M4 20l7-7"></path>
                <path d="M10 14l4 4"></path>
              </svg>
            </span>
            <span class="config-nav-copy">
              <strong>Tratamento</strong>
            </span>
          </span>
          <span class="config-nav-toggle-caret" aria-hidden="true">v</span>
        </button>
        <nav class="config-nav-panel config-nav-subpanel">
          <a class="config-nav-link-row <%= activeSection === 'maintenanceRun' ? 'active' : '' %>" href="/config/maintenance/run">Uso</a>
          <a class="config-nav-link-row <%= activeSection === 'maintenanceSettings' ? 'active' : '' %>" href="/config/maintenance/settings">Configuração</a>
        </nav>
      </div>

      <div class="config-nav-tool config-nav-collapsible" data-accordion-scope="root" data-collapsed="<%= isEnrichmentOpen ? 'false' : 'true' %>">
        <button class="config-nav-toggle" type="button" aria-expanded="<%= isEnrichmentOpen ? 'true' : 'false' %>">
          <span class="config-nav-toggle-main">
            <span class="config-nav-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M12 3l1.9 4.6L19 9.5l-3.8 3.3 1.1 5-4.3-2.6-4.3 2.6 1.1-5L5 9.5l5.1-1.9z"></path>
              </svg>
            </span>
            <span class="config-nav-copy">
              <strong>IA e mídia</strong>
            </span>
          </span>
          <span class="config-nav-toggle-caret" aria-hidden="true">v</span>
        </button>
        <nav class="config-nav-panel config-nav-subpanel">
          <a class="config-nav-link-row <%= activeSection === 'enrichmentRun' ? 'active' : '' %>" href="/config/enrichment/run">Uso</a>
          <a class="config-nav-link-row <%= activeSection === 'enrichmentSettings' ? 'active' : '' %>" href="/config/enrichment/settings">Configuração</a>
        </nav>
      </div>

      <div class="config-nav-tool config-nav-collapsible" data-accordion-scope="root" data-collapsed="<%= isLocalLibraryOpen ? 'false' : 'true' %>">
        <button class="config-nav-toggle" type="button" aria-expanded="<%= isLocalLibraryOpen ? 'true' : 'false' %>">
          <span class="config-nav-toggle-main">
            <span class="config-nav-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M4 7h16"></path>
                <path d="M4 12h16"></path>
                <path d="M4 17h16"></path>
                <path d="M8 4v16"></path>
              </svg>
            </span>
            <span class="config-nav-copy">
              <strong>Biblioteca</strong>
            </span>
          </span>
          <span class="config-nav-toggle-caret" aria-hidden="true">v</span>
        </button>
        <nav class="config-nav-panel config-nav-subpanel">
          <a class="config-nav-link-row <%= activeSection === 'localLibraryRun' ? 'active' : '' %>" href="/config/local-library/run">Uso</a>
          <a class="config-nav-link-row <%= activeSection === 'localLibrarySettings' ? 'active' : '' %>" href="/config/local-library/settings">Configuração</a>
        </nav>
      </div>

      <a class="config-nav-link-row <%= activeSection === 'settings' ? 'active' : '' %>" href="/config/settings">Preferências</a>
      <a class="config-nav-link-row" href="/monitor">Monitor ao vivo</a>

    </nav>
  </div>
</aside>