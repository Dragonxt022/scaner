<aside class="config-sidebar">
  <div class="config-sidebar-card">
    <div class="config-sidebar-profile">
      <div class="config-sidebar-brand">
        <span class="config-sidebar-brand-mark">AP</span>
        <div>
          <p class="panel-kicker">Painel administrativo</p>
          <h3>Central de comando</h3>
        </div>
      </div>
      <% if (currentUser) { %>
        <p class="config-note">Perfil <strong><%= currentUser.role === 'admin' ? 'admin' : 'usuario' %></strong> • CPF <strong><%= currentUser.cpf %></strong></p>
        <p class="config-sidebar-user"><%= currentUser.full_name %></p>
      <% } %>
    </div>

    <div class="config-nav-group">
      <p class="config-nav-title">Visao geral</p>
      <nav class="config-nav">
        <a class="config-nav-button <%= activeSection === 'dashboard' ? 'active' : '' %>" href="/config">Dashboard</a>
      </nav>
    </div>

    <div class="config-nav-group config-nav-collapsible" data-collapsed="<%= !['users', 'settings', 'audit'].includes(activeSection) %>">
      <p class="config-nav-title">Configuracao</p>
      <button class="config-nav-toggle" type="button" aria-expanded="<%= ['users', 'settings', 'audit'].includes(activeSection) ? 'true' : 'false' %>">
        <span>Exibir submenu</span>
      </button>
      <nav class="config-nav config-nav-panel">
        <div class="config-nav-subgroup">
          <p class="config-nav-subtitle">Seguranca e pessoas</p>
          <a class="config-nav-button config-nav-button-sub <%= activeSection === 'users' ? 'active' : '' %>" href="/config/users">Usuarios</a>
        </div>
        <div class="config-nav-subgroup">
          <p class="config-nav-subtitle">Politicas do sistema</p>
          <a class="config-nav-button config-nav-button-sub <%= activeSection === 'settings' ? 'active' : '' %>" href="/config/settings">Preferencias</a>
        </div>
        <div class="config-nav-subgroup">
          <p class="config-nav-subtitle">Auditoria</p>
          <a class="config-nav-button config-nav-button-sub <%= activeSection === 'audit' ? 'active' : '' %>" href="/config/audit">Rastreabilidade</a>
        </div>
      </nav>
    </div>

    <div class="config-nav-group config-nav-collapsible" data-collapsed="<%= !['indexing', 'downloads', 'logs', 'maintenance', 'enrichment'].includes(activeSection) %>">
      <p class="config-nav-title">Ferramentas de execucao</p>
      <button class="config-nav-toggle" type="button" aria-expanded="<%= ['indexing', 'downloads', 'logs', 'maintenance', 'enrichment'].includes(activeSection) ? 'true' : 'false' %>">
        <span>Exibir submenu</span>
      </button>
      <nav class="config-nav config-nav-panel">
        <a class="config-nav-button" href="/monitor">Monitor ao vivo</a>
        <a class="config-nav-button <%= activeSection === 'indexing' ? 'active' : '' %>" href="/config/indexing">Indexacao</a>
        <a class="config-nav-button <%= activeSection === 'downloads' ? 'active' : '' %>" href="/config/downloads">Downloads</a>
        <a class="config-nav-button <%= activeSection === 'logs' ? 'active' : '' %>" href="/config/logs">Logs e erros</a>
        <a class="config-nav-button <%= activeSection === 'maintenance' ? 'active' : '' %>" href="/config/maintenance">Tratamento</a>
        <a class="config-nav-button <%= activeSection === 'enrichment' ? 'active' : '' %>" href="/config/enrichment">IA e midia</a>
      </nav>
    </div>

    <div class="config-actions">
      <a class="detail-action-secondary config-sidebar-cta" href="/">Ir para busca</a>
    </div>
  </div>
</aside>
