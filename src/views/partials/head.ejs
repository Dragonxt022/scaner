<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="shortcut icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/styles.css" />
    <script>
      window.__APP_CONTEXT__ = {
        authEnabled: <%- JSON.stringify(typeof authEnabled !== 'undefined' ? authEnabled : true) %>,
        canAccessAdmin: <%- JSON.stringify(typeof canAccessAdmin !== 'undefined' ? canAccessAdmin : false) %>,
        currentUser: <%- JSON.stringify(typeof currentUser !== 'undefined' ? currentUser : null) %>
      };
    </script>
  </head>
  <body<% if (typeof bodyClass !== 'undefined' && bodyClass) { %> class="<%= bodyClass %>"<% } %><% if (typeof bodyPage !== 'undefined' && bodyPage) { %> data-page="<%= bodyPage %>"<% } %>>
