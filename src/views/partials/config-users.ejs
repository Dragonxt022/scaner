<article class="config-card">
  <div class="section-head">
    <div>
      <p class="panel-kicker">Usuarios</p>
      <h3>Cadastro e controle</h3>
    </div>
  </div>

  <div class="form-grid">
    <label>
      <span>Nome completo</span>
      <input id="userFullName" type="text" placeholder="Nome do usuario" />
    </label>
    <label>
      <span>CPF</span>
      <input id="userCpf" type="text" inputmode="numeric" maxlength="14" placeholder="11 digitos" />
    </label>
    <label>
      <span>Perfil</span>
      <select id="userRole">
        <option value="user" selected>Usuario</option>
        <option value="admin">Admin</option>
      </select>
    </label>
    <label>
      <span>Status</span>
      <select id="userIsActive">
        <option value="true" selected>Ativo</option>
        <option value="false">Inativo</option>
      </select>
    </label>
  </div>

  <div class="form-grid">
    <label>
      <span>Senha</span>
      <input id="userPassword" type="password" placeholder="Senha segura" />
    </label>
    <label>
      <span>Troca obrigatoria</span>
      <select id="userMustChangePassword">
        <option value="true" selected>Sim</option>
        <option value="false">Nao</option>
      </select>
    </label>
  </div>

  <div class="form-grid">
    <label>
      <span>ID em edicao</span>
      <input id="userEditId" type="text" readonly placeholder="Novo cadastro" />
    </label>
  </div>

  <div class="button-row">
    <button id="userSaveButton" class="primary-button" type="button">Salvar usuario</button>
    <button id="userResetButton" class="ghost-button" type="button">Limpar formulario</button>
  </div>

  <p id="userManagementFeedback" class="config-note">Cadastre usuarios com CPF e senha forte.</p>
  <div class="table-toolbar">
    <label>
      <span>Filtrar usuarios</span>
      <input id="userSearch" type="text" placeholder="Nome, CPF, perfil ou status" />
    </label>
  </div>
  <div id="userList" class="table-shell"></div>

  <div class="config-section-grid compact-grid">
    <div>
      <h4 class="config-subtitle">Solicitacoes de recuperacao</h4>
      <div class="table-toolbar">
        <label>
          <span>Filtrar solicitacoes</span>
          <input id="passwordResetSearch" type="text" placeholder="CPF, nome, status, IP ou admin" />
        </label>
      </div>
      <div id="passwordResetRequestList" class="table-shell"></div>
    </div>
  </div>
</article>
